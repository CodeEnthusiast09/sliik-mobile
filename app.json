{
  "expo": {
    "name": "Sliik",
    "slug": "sliik",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sliik",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.sliik.app"
    },
    "android": {
      "package": "com.sliik.app",
      "adaptiveIcon": {
        "backgroundColor": "#4B2E46",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F0B08",
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "cover",
          "dark": {
            "backgroundColor": "#0F0B08",
            "image": "./assets/images/splash-icon-dark.png"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Sliik accesses your photos so you can set a profile photo and add portfolio images.",
          "cameraPermission": "Sliik accesses your camera so you can take a profile photo or portfolio image.",
          "microphonePermission": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Sliik accesses your location so you can find providers near you."
        }
      ],
      "expo-web-browser",
      "expo-notifications",
      "expo-image",
      "@react-native-community/datetimepicker",
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
